<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_inherit_invoice_payment_entry" model="ir.ui.view">
        <field name="name">account.move.form.inherit.invoice.payment.entry</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_invoice_payment_wizard"
                    type="object"
                    string="Payment"
                    class="btn-primary"
                    invisible="move_type != 'out_invoice' or state != 'posted'"
                />
                <button
                    name="action_reconcile_payment_entries"
                    type="object"
                    string="Reconcile Payments"
                    class="btn-secondary"
                    invisible="move_type != 'out_invoice' or state != 'posted' or payment_state == 'paid'"
                />
            </xpath>
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button
                    class="oe_stat_button"
                    name="action_view_payment_entries"
                    type="object"
                    icon="fa-money"
                    invisible="move_type != 'out_invoice'"
                >
                    <field name="payment_entry_count" string="Payment Entries" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
