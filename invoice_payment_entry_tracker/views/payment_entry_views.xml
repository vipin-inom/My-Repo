<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="seq_invoice_payment_entry" model="ir.sequence">
        <field name="name">Invoice Payment Entry</field>
        <field name="code">invoice.payment.entry</field>
        <field name="prefix">IPE/%(year)s/</field>
        <field name="padding">4</field>
    </record>

    <record id="view_invoice_payment_entry_tree" model="ir.ui.view">
        <field name="name">invoice.payment.entry.tree</field>
        <field name="model">invoice.payment.entry</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="invoice_id"/>
                <field name="payment_id"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="currency_id" optional="hide"/>
                <field name="payment_date"/>
                <field name="journal_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_payment_entry_form" model="ir.ui.view">
        <field name="name">invoice.payment.entry.form</field>
        <field name="model">invoice.payment.entry</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="invoice_id"/>
                        <field name="payment_id"/>
                        <field name="partner_id"/>
                        <field name="amount"/>
                        <field name="currency_id"/>
                        <field name="payment_date"/>
                        <field name="journal_id"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_payment_entry" model="ir.actions.act_window">
        <field name="name">Invoice Payment Entries</field>
        <field name="res_model">invoice.payment.entry</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
