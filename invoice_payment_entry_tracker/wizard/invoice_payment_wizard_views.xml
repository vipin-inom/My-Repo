<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_invoice_payment_wizard_form" model="ir.ui.view">
        <field name="name">invoice.payment.wizard.form</field>
        <field name="model">invoice.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Payment">
                <group>
                    <field name="invoice_id"/>
                    <field name="partner_id"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                </group>
                <group>
                    <field name="amount"/>
                    <field name="payment_date"/>
                    <field name="journal_id"/>
                    <field name="payment_method_line_id"/>
                    <field name="communication"/>
                </group>
                <footer>
                    <button name="action_create_payment" type="object" string="Create Payment" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
